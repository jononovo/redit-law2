{
  "manifest_version": 3,
  "name": "SecureFill",
  "version": "2.0.0",
  "description": "Fill form fields from a referenced source, keeping the values out of the calling assistant's context.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "webNavigation"],
  "host_permissions": ["https://creditclaw.com/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["page-bridge.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["https://*/*"],
      "js": ["lib/field-detect.js", "lib/fill-engine.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "options_page": "setup.html",
  "action": {
    "default_title": "SecureFill",
    "default_popup": "setup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
