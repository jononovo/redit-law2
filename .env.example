# Environment variables for local development.
# Copy to .env.local and fill in real values (.env.local is gitignored, never commit it).
# Replit uses Secrets instead of this file — when you add a var here, set it in Replit Secrets too.
# Names only; no values.

# --- App / runtime ---
NODE_OPTIONS=
PORT=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_BASE_URL=
TENANT_OVERRIDE=

# --- Database (Postgres) ---
# Local dev points at a local Postgres. Replit's `helium` host is only reachable inside the Repl.
DATABASE_URL=
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=

# --- Firebase Auth ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Stripe (Crypto Onramp) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_ONRAMP=

# --- Privy (Rail 1 server wallets) ---
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_AUTHORIZATION_KEY=

# --- CrossMint (Rail 2 smart wallets) ---
CROSSMINT_ENV=
NEXT_PUBLIC_CROSSMINT_CLIENT_API_KEY=
CROSSMINT_SERVER_API_KEY=
CROSSMINT_WEBHOOK_SECRET=

# --- Managed agents (Crossmint Agent Checkout runtime) ---
# Reuses NEXT_PUBLIC_CROSSMINT_CLIENT_API_KEY above (no separate key); the
# Crossmint console key just needs the agent-checkouts + buyer-profiles scopes.
# Set AGENT_CHECKOUT_DEBUG=1 to log the full (PAN-redacted) checkout payload.
AGENT_CHECKOUT_DEBUG=

# --- Base chain / USDC ---
BASE_RPC_URL=
USDC_CONTRACT_ADDRESS=

# --- SendGrid (email) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SUPPORT_EMAIL=

# --- Anthropic / Perplexity (ASX Score scanner) ---
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# --- Cloudflare (managed webhook tunnels) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# --- Secrets / HMAC ---
CRON_SECRET=
CONFIRMATION_HMAC_SECRET=
HMAC_SECRET=
UNIFIED_APPROVAL_HMAC_SECRET=
INTERNAL_API_SECRET=
